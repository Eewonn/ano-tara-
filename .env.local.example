# Get a free Groq API key at https://console.groq.com/keys
# Used by the "Ask the local guide" AI chat + story trivia
VITE_GROQ_API_KEY=gsk_your_key_here

# Optional: Tavily for real-time historic image search
# Free tier (1000 searches/month) at https://tavily.com
# Used as fallback for Then/Now toggle when Wikimedia has no historic photo
VITE_TAVILY_API_KEY=tvly_your_key_here
